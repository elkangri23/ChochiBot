# ChochiBot Environment Variables

# Telegram
TELEGRAM_BOT_TOKEN="your_telegram_bot_token"
TELEGRAM_ALLOWED_USER_IDS="123456789,987654321"

# LLM Providers
DEFAULT_LLM_PROVIDER="groq" # groq, openrouter, ollama
GROQ_MODEL="llama-3.3-70b-versatile"
OPENROUTER_MODEL="google/gemini-2.0-flash-thinking-exp:free"
OLLAMA_MODEL="llama3.3"
GROQ_API_KEY="your_groq_api_key"
OPENROUTER_API_KEY=""
OLLAMA_BASE_URL="http://127.0.0.1:11434"

# Database
DB_PATH="./data/chochibot.sqlite"

# PC Integration / FileSystem options
ALLOWED_FS_PATHS="C:/Users/amoles/Desktop,C:/Temp"
VSCODE_PATH="code"
